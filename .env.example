# .env.example
# 複製此檔案為 .env 並填入正式環境的設定值
# 警告：.env 檔案已加入 .gitignore，請勿將含有真實密鑰的 .env 提交至版本控制

# ── 資料庫設定 ────────────────────────────────────────────────────────────────
# 正式環境（PostgreSQL）
DB_URL=postgresql+asyncpg://user:password@localhost:5432/attendance_db
# 開發環境（SQLite）：
# DB_URL=sqlite+aiosqlite:///./test.db

# ── JWT 安全設定 ───────────────────────────────────────────────────────────────
# 警告：務必更換為強隨機金鑰！產生方法：
#   openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── 應用程式設定 ───────────────────────────────────────────────────────────────
# 正式環境設為 false，避免 SQL 語句洩漏至日誌
DEBUG=false
